{
  "name": "pvp-wars",
  "version": "2.0.0",
  "description": "PVP WARS — Multiplayer Voxel Web Game",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"node server/index.js\" \"npx vite\"",
